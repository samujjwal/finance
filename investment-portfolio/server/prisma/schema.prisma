// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  userId                String    @unique @map("user_id")
  username              String    @unique
  email                 String?   @unique
  passwordHash          String    @map("password_hash")
  firstName             String    @map("first_name")
  surname               String
  designation           String?
  branchId              String    @map("branch_id")
  userTypeId            String    @map("user_type_id")
  telephone             String?
  mobile                String?
  extension             String?
  status                String    @default("ACTIVE")
  failedLoginAttempts   Int       @default(0) @map("failed_login_attempts")
  lockedUntil           DateTime? @map("locked_until")
  lockReason            String?   @map("lock_reason")
  isActive              Boolean   @default(true) @map("is_active")
  lastPasswordChange    DateTime? @map("last_password_change")
  organizationId        String?   @map("organization_id")
  createdBy             String?   @map("created_by")
  approvedBy            String?   @map("approved_by")
  approvedAt            DateTime? @map("approved_at")
  rejectionReason       String?   @map("rejection_reason")
  suspensionReason      String?   @map("suspension_reason")
  lastLogin             DateTime? @map("last_login")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  branch                Branch    @relation(fields: [branchId], references: [id])
  userType              UserType  @relation(fields: [userTypeId], references: [id])
  userRoles             UserRole[]
  userSessions          UserSession[]
  createdUsers          User[]    @relation("UserCreatedBy")
  creator               User?     @relation("UserCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedUsers         User[]    @relation("UserApprovedBy")
  approver              User?     @relation("UserApprovedBy", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  auditLogs             AuditLog[]
  requestedWorkflows    ApprovalWorkflow[] @relation("RequestedBy")
  approvedWorkflows     ApprovalWorkflow[] @relation("ApprovedBy")
  transactionsCreated   Transaction[] @relation("TransactionCreatedBy")
  transactionsApproved  Transaction[] @relation("TransactionApprovedBy")
  rolesCreated          Role[] @relation("RoleCreatedBy")
  rolesApproved         Role[] @relation("RoleApprovedBy")
  roleFunctionsAssigned RoleFunction[] @relation("RoleFunctionAssignedBy")
  roleFunctionsApproved RoleFunction[] @relation("RoleFunctionApprovedBy")
  userRolesAssigned     UserRole[] @relation("UserRoleAssignedBy")
  userRolesApproved     UserRole[] @relation("UserRoleApprovedBy")
  systemConfigsUpdated  SystemConfig[]
  journalEntriesPosted  JournalEntry[] @relation("JournalPostedBy")
  journalEntriesCreated JournalEntry[] @relation("JournalCreatedBy")

  @@map("users")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

// ========== MULTI-TENANT FOUNDATION (Phase 1) ==========

model Tenant {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("ACTIVE")
  plan      String   @default("FREE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

/// Business organization entity (the company using the platform, with module flags)
model Organization {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  hasInvestment Boolean  @default(true)  @map("has_investment")
  hasAccounting Boolean  @default(false) @map("has_accounting")
  hasInventory  Boolean  @default(false) @map("has_inventory")
  baseCurrency  String   @default("NPR") @map("base_currency")
  panNumber     String?  @map("pan_number")
  vatNumber     String?  @map("vat_number")
  address       String?
  phone         String?
  email         String?
  isActive      Boolean  @default(true)  @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  // Relations
  fiscalYears       FiscalYear[]
  portfolioAccounts PortfolioAccount[]
  accountGroups     AccountGroup[]
  ledgerAccounts    LedgerAccount[]
  journalEntries    JournalEntry[]
  vouchers          Voucher[]
  customers         Customer[]
  vendors           Vendor[]
  bankAccounts      BankAccount[]
  invoices          Invoice[]
  bills             Bill[]
  vatConfig         VatConfig?
  tdsConfigs        TdsConfig[]

  @@map("organizations")
}

model FiscalYear {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  isClosed       Boolean  @default(false) @map("is_closed")
  closedBy       String?  @map("closed_by")
  closedAt       DateTime? @map("closed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  journalEntries JournalEntry[]
  vouchers       Voucher[]

  @@map("fiscal_years")
}

// ========== INVESTMENT DOMAIN – Instrument replaces the old Company ==========

/// NEPSE-listed securities (replaces Company). DB table kept as "companies" for zero-downtime migration.
model Instrument {
  id             String   @id @default(cuid())
  serialNumber   Int?     @map("serial_number")
  symbol         String   @unique
  companyName    String   @map("company_name")
  symbol2        String?  @map("symbol2")
  sector         String?
  symbol3        String?  @map("symbol3")
  instrumentType String?  @map("instrument_type")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  transactions      Transaction[]
  monthlySummaries  MonthlySummary[]
  portfolioHoldings PortfolioHolding[]

  @@map("companies") // DB table name preserved for backward-compat
}

/// Investor's brokerage/DP account (one org can have multiple)
model PortfolioAccount {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  accountNumber  String? @map("account_number")
  boId           String? @map("bo_id")
  dpCode         String? @map("dp_code")
  investorType   String? @map("investor_type")
  isDefault      Boolean @default(false) @map("is_default")
  isActive       Boolean @default(true)  @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("portfolio_accounts")
}

model Transaction {
  id                      String   @id @default(cuid())
  companySymbol           String   @map("company_symbol")
  billNo                  String?  @map("bill_no")
  transactionDate         String   @map("transaction_date")
  transactionType         String   @map("transaction_type")
  purchaseQuantity        Int      @default(0) @map("purchase_quantity")
  purchasePricePerUnit    Float?   @map("purchase_price_per_unit")
  totalPurchaseAmount     Float?   @map("total_purchase_amount")
  purchaseCommission      Float?   @map("purchase_commission")
  purchaseDpCharges       Float?   @map("purchase_dp_charges")
  sebonFeePurchase        Float?   @map("sebon_fee_purchase")
  otherChargesPurchase    Float?   @map("other_charges_purchase")
  totalPurchaseCost       Float?   @map("total_purchase_cost")
  salesQuantity           Int      @default(0) @map("sales_quantity")
  salesPricePerUnit       Float?   @map("sales_price_per_unit")
  totalSalesAmount        Float?   @map("total_sales_amount")
  salesCommission         Float?   @map("sales_commission")
  salesDpCharges          Float?   @map("sales_dp_charges")
  sebonFeeSales           Float?   @map("sebon_fee_sales")
  otherChargesSales       Float?   @map("other_charges_sales")
  totalSalesCharges       Float?   @map("total_sales_charges")
  principalCostNfrs       Float?   @map("principal_cost_nfrs")
  transactionCostNfrs     Float?   @map("transaction_cost_nfrs")
  unitSum                 Float?   @map("unit_sum")
  waccNfrs                Float?   @map("wacc_nfrs")
  profitLossNfrs          Float?   @map("profit_loss_nfrs")
  capitalGainTax          Float?   @map("capital_gain_tax")
  netReceivables          Float?   @map("net_receivables")
  principalAmountTax      Float?   @map("principal_amount_tax")
  tcTax                   Float?   @map("tc_tax")
  waccTax                 Float?   @map("wacc_tax")
  profitLossTax           Float?   @map("profit_loss_tax")
  status                  String   @default("DRAFT") @map("status")
  approvedBy              String?  @map("approved_by")
  approvedAt              DateTime? @map("approved_at")
  createdBy               String   @map("created_by")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  // Relations
  instrument Instrument @relation(fields: [companySymbol], references: [symbol])
  approver   User?      @relation("TransactionApprovedBy", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator    User       @relation("TransactionCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([companySymbol, transactionDate])
  @@map("transactions")
}

model MonthlySummary {
  id                           String   @id @default(cuid())
  monthName                    String?  @map("month_name")
  serialNo                     Int?     @map("serial_no")
  companySymbol                String   @map("company_symbol")
  sector                       String?
  purchaseQuantity             Int?     @map("purchase_quantity")
  totalPurchaseAmount          Float?   @map("total_purchase_amount")
  salesQuantity                Int?     @map("sales_quantity")
  salesAmount                  Float?   @map("sales_amount")
  tcNfrs                       Float?   @map("tc_nfrs")
  closingUnits                 Int?     @map("closing_units")
  waccNfrs                     Float?   @map("wacc_nfrs")
  profitLossNfrs               Float?   @map("profit_loss_nfrs")
  purchaseCommission           Float?   @map("purchase_commission")
  purchaseDpCharges            Float?   @map("purchase_dp_charges")
  totalPurchaseCommission      Float?   @map("total_purchase_commission")
  investmentCostWithCommission Float?   @map("investment_cost_with_commission")
  salesCommission              Float?   @map("sales_commission")
  salesDpCharges               Float?   @map("sales_dp_charges")
  totalSalesCommission         Float?   @map("total_sales_commission")
  capitalGainTax               Float?   @map("capital_gain_tax")
  netReceivables               Float?   @map("net_receivables")
  tcTax                        Float?   @map("tc_tax")
  waccTax                      Float?   @map("wacc_tax")
  profitLossTax                Float?   @map("profit_loss_tax")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  // Relations
  instrument Instrument @relation(fields: [companySymbol], references: [symbol])

  @@map("monthly_summary")
}

model PortfolioHolding {
  id                  String   @id @default(cuid())
  companySymbol       String   @unique @map("company_symbol")
  totalQuantity       Int      @default(0) @map("total_quantity")
  availableQuantity   Int      @default(0) @map("available_quantity")
  pledgedQuantity     Int      @default(0) @map("pledged_quantity")
  weightedAverageCost Float?   @map("weighted_average_cost")
  totalCost           Float?   @map("total_cost")
  marketValue         Float?   @map("market_value")
  unrealizedGainLoss  Float?   @map("unrealized_gain_loss")
  unrealizedGainLossPercent Float? @map("unrealized_gain_loss_percent")
  lastUpdated         DateTime @default(now()) @map("last_updated")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  instrument Instrument @relation(fields: [companySymbol], references: [symbol])

  @@map("portfolio_holdings")
}

model Validation {
  id             String   @id @default(cuid())
  validationType String   @map("validation_type")
  validationData String   @map("validation_data")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("validation")
}

// ========== USER MANAGEMENT ==========

model UserType {
  id          String   @id
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  users       User[]
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("user_types")
}

model Function {
  id          String   @id
  name        String   @unique
  description String?
  module      String
  isActive    Boolean  @default(true)
  roleFunctions RoleFunction[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("functions")
}

model Branch {
  id        String   @id
  name      String
  code      String   @unique
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("branches")
}

// ========== ROLE MANAGEMENT ==========

model Role {
  id               String         @id
  name             String
  userTypeId       String         @map("user_type_id")
  description      String?
  status           String         @default("PENDING_APPROVAL")
  isSystem         Boolean        @default(false) @map("is_system")
  createdBy        String?        @map("created_by")
  approvedBy       String?        @map("approved_by")
  approvedAt       DateTime?      @map("approved_at")
  rejectionReason  String?        @map("rejection_reason")
  suspensionReason String?        @map("suspension_reason")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // Relations
  userType         UserType       @relation(fields: [userTypeId], references: [id])
  roleFunctions    RoleFunction[]
  userRoles        UserRole[]
  creator          User?          @relation("RoleCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver         User?          @relation("RoleApprovedBy", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("roles")
}

model RoleFunction {
  id              String    @id @default(cuid())
  roleId          String    @map("role_id")
  functionId      String    @map("function_id")
  assignedBy      String?   @map("assigned_by")
  assignedAt      DateTime  @default(now()) @map("assigned_at")
  status          String    @default("PENDING_APPROVAL")
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")

  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  function   Function @relation(fields: [functionId], references: [id], onDelete: Cascade)
  assigner   User?    @relation("RoleFunctionAssignedBy", fields: [assignedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver   User?    @relation("RoleFunctionApprovedBy", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("role_functions")
}

model UserRole {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  roleId          String    @map("role_id")
  assignedBy      String?   @map("assigned_by")
  assignedAt      DateTime  @default(now()) @map("assigned_at")
  status          String    @default("PENDING_APPROVAL")
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")
  effectiveFrom   DateTime  @default(now()) @map("effective_from")
  effectiveTo     DateTime? @map("effective_to")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver User? @relation("UserRoleApprovedBy", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_roles")
}

// ========== AUDIT & WORKFLOW ==========

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  oldValues  String?  @map("old_values")
  newValues  String?  @map("new_values")
  userId     String   @map("user_id")
  timestamp  DateTime @default(now())
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  comment    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
  @@map("audit_logs")
}

model ApprovalWorkflow {
  id              String    @id @default(cuid())
  entityType      String    @map("entity_type")
  entityId        String    @map("entity_id")
  action          String
  requestedBy     String    @map("requested_by")
  requestedAt     DateTime  @default(now()) @map("requested_at")
  status          String    @default("PENDING")
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")

  requester User  @relation("RequestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)
  approver  User? @relation("ApprovedBy", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedBy])
  @@map("approval_workflows")
}

// ========== SYSTEM CONFIGURATION ==========

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String?
  description String?
  category    String
  isEditable  Boolean  @default(true) @map("is_editable")
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @default(now()) @map("updated_at")

  user User? @relation(fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("system_config")
}

// Nepal NEPSE fee and tax rate table – authoritative source for all charge calculations
model FeeRate {
  id           String   @id @default(cuid())
  // e.g. "Equity", "Bond_Debenture", "Bond_Other", "MutualFund", "MeroShare", "Government"
  instrument   String
  // e.g. "Brokerage", "SEBONFee", "DPCharge", "CGT", "Maintenance", "Opening", "PledgeFee"
  category     String
  description  String
  // Bracket bounds (null minAmount implies 0, null maxAmount implies no upper limit)
  minAmount    Float?   @map("min_amount")
  maxAmount    Float?   @map("max_amount")
  // Rate as a true decimal fraction (0.0036 means 0.36%)
  rate         Float?
  // Flat fixed charge in NPR (e.g. 25 for DP, 100 for annual maintenance)
  fixedAmount  Float?   @map("fixed_amount")
  // Minimum floor when rule says "X% or Rs. Y, whichever is higher"
  minFixed     Float?   @map("min_fixed")
  // Applicable investor type (null = all); one of "Individual" | "Institutional"
  investorType String?  @map("investor_type")
  // "ShortTerm" (<1 year) | "LongTerm" (>=1 year) – used for CGT
  termType     String?  @map("term_type")
  remarks      String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("fee_rates")
}

// ========== ACCOUNTING DOMAIN – Phase 3 ==========

model AccountGroup {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  code           String
  name           String
  parentId       String?  @map("parent_id")
  /// ASSET | LIABILITY | EQUITY | INCOME | EXPENSE
  groupType      String   @map("group_type")
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id])
  parent         AccountGroup?   @relation("AccountGroupHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children       AccountGroup[]  @relation("AccountGroupHierarchy")
  ledgerAccounts LedgerAccount[]

  @@unique([organizationId, code])
  @@map("account_groups")
}

model LedgerAccount {
  id              String  @id @default(cuid())
  organizationId  String  @map("organization_id")
  accountGroupId  String  @map("account_group_id")
  code            String
  name            String
  /// ASSET | LIABILITY | EQUITY | INCOME | EXPENSE
  accountType     String  @map("account_type")
  openingBalance  Float   @default(0) @map("opening_balance")
  currentBalance  Float   @default(0) @map("current_balance")
  isSystem        Boolean @default(false) @map("is_system")
  isActive        Boolean @default(true)  @map("is_active")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  organization  Organization       @relation(fields: [organizationId], references: [id])
  accountGroup  AccountGroup       @relation(fields: [accountGroupId], references: [id])
  journalLines  JournalEntryLine[]
  bankAccount   BankAccount?

  @@unique([organizationId, code])
  @@map("ledger_accounts")
}

model JournalEntry {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  fiscalYearId   String?   @map("fiscal_year_id")
  entryDate      DateTime  @map("entry_date")
  reference      String?
  narration      String?
  totalDebit     Float     @default(0) @map("total_debit")
  totalCredit    Float     @default(0) @map("total_credit")
  /// DRAFT | POSTED | REVERSED
  status         String    @default("DRAFT")
  postedBy       String?   @map("posted_by")
  postedAt       DateTime? @map("posted_at")
  /// Marks entries auto-posted from investment bridge
  isAutoPosted   Boolean   @default(false) @map("is_auto_posted")
  /// TRANSACTION | INVOICE | BILL | MANUAL
  sourceType     String?   @map("source_type")
  sourceId       String?   @map("source_id")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt      @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id])
  fiscalYear   FiscalYear?       @relation(fields: [fiscalYearId], references: [id])
  lines        JournalEntryLine[]
  poster       User?             @relation("JournalPostedBy", fields: [postedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator      User              @relation("JournalCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([organizationId, entryDate, status])
  @@map("journal_entries")
}

model JournalEntryLine {
  id              String  @id @default(cuid())
  journalEntryId  String  @map("journal_entry_id")
  ledgerAccountId String  @map("ledger_account_id")
  debit           Float   @default(0)
  credit          Float   @default(0)
  narration       String?
  createdAt       DateTime @default(now()) @map("created_at")

  journalEntry            JournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  ledgerAccount           LedgerAccount   @relation(fields: [ledgerAccountId], references: [id])
  matchedBankTransactions BankTransaction[]

  @@map("journal_entry_lines")
}

/// Voucher types: PAYMENT | RECEIPT | JOURNAL | CONTRA
model Voucher {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  voucherType     String    @map("voucher_type")
  voucherNumber   String    @map("voucher_number")
  fiscalYearId    String?   @map("fiscal_year_id")
  voucherDate     DateTime  @map("voucher_date")
  narration       String?
  totalAmount     Float     @default(0) @map("total_amount")
  /// DRAFT | PENDING_APPROVAL | APPROVED | POSTED
  status          String    @default("DRAFT")
  submittedBy     String?   @map("submitted_by")
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")
  journalEntryId  String?   @map("journal_entry_id")
  createdBy       String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  fiscalYear   FiscalYear?  @relation(fields: [fiscalYearId], references: [id])

  @@unique([organizationId, voucherType, voucherNumber])
  @@map("vouchers")
}

// ========== COMMERCIAL DOMAIN – Phases 4 ==========

model Customer {
  id              String  @id @default(cuid())
  organizationId  String  @map("organization_id")
  code            String
  name            String
  address         String?
  phone           String?
  email           String?
  panNumber       String? @map("pan_number")
  creditLimit     Float?  @map("credit_limit")
  /// Payment terms in days
  paymentTerms    Int?    @map("payment_terms")
  ledgerAccountId String? @map("ledger_account_id")
  isActive        Boolean @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  invoices     Invoice[]

  @@unique([organizationId, code])
  @@map("customers")
}

model Vendor {
  id              String  @id @default(cuid())
  organizationId  String  @map("organization_id")
  code            String
  name            String
  address         String?
  phone           String?
  email           String?
  panNumber       String? @map("pan_number")
  paymentTerms    Int?    @map("payment_terms")
  ledgerAccountId String? @map("ledger_account_id")
  isActive        Boolean @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  bills         Bill[]
  tdsDeductions TdsDeduction[]

  @@unique([organizationId, code])
  @@map("vendors")
}

model Invoice {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  customerId     String    @map("customer_id")
  invoiceNumber  String    @map("invoice_number")
  invoiceDate    DateTime  @map("invoice_date")
  dueDate        DateTime? @map("due_date")
  subtotal       Float     @default(0)
  taxAmount      Float     @default(0) @map("tax_amount")
  vatAmount      Float     @default(0) @map("vat_amount")
  total          Float     @default(0)
  paidAmount     Float     @default(0) @map("paid_amount")
  /// DRAFT | POSTED | PARTIALLY_PAID | PAID | CANCELLED
  status         String    @default("DRAFT")
  narration      String?
  journalEntryId String?   @map("journal_entry_id")
  postedBy       String?   @map("posted_by")
  postedAt       DateTime? @map("posted_at")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  lines        InvoiceLine[]

  @@unique([organizationId, invoiceNumber])
  @@map("invoices")
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @map("unit_price")
  amount      Float   @default(0)
  taxAmount   Float   @default(0) @map("tax_amount")
  vatAmount   Float   @default(0) @map("vat_amount")
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_lines")
}

model Bill {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  vendorId       String    @map("vendor_id")
  billNumber     String    @map("bill_number")
  billDate       DateTime  @map("bill_date")
  dueDate        DateTime? @map("due_date")
  subtotal       Float     @default(0)
  taxAmount      Float     @default(0) @map("tax_amount")
  tdsAmount      Float     @default(0) @map("tds_amount")
  total          Float     @default(0)
  paidAmount     Float     @default(0) @map("paid_amount")
  /// DRAFT | POSTED | PARTIALLY_PAID | PAID | CANCELLED
  status         String    @default("DRAFT")
  narration      String?
  journalEntryId String?   @map("journal_entry_id")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  vendor       Vendor       @relation(fields: [vendorId], references: [id])
  lines        BillLine[]

  @@unique([organizationId, billNumber])
  @@map("bills")
}

model BillLine {
  id          String  @id @default(cuid())
  billId      String  @map("bill_id")
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @map("unit_price")
  amount      Float   @default(0)
  tdsSection  String? @map("tds_section")
  tdsAmount   Float   @default(0) @map("tds_amount")
  createdAt   DateTime @default(now()) @map("created_at")

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@map("bill_lines")
}

model BankAccount {
  id              String  @id @default(cuid())
  organizationId  String  @map("organization_id")
  accountName     String  @map("account_name")
  accountNumber   String  @map("account_number")
  bankName        String  @map("bank_name")
  ledgerAccountId String  @unique @map("ledger_account_id")
  currentBalance  Float   @default(0) @map("current_balance")
  isActive        Boolean @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id])
  ledgerAccount   LedgerAccount    @relation(fields: [ledgerAccountId], references: [id])
  reconciliations Reconciliation[]

  @@map("bank_accounts")
}

model Reconciliation {
  id               String    @id @default(cuid())
  bankAccountId    String    @map("bank_account_id")
  statementDate    DateTime  @map("statement_date")
  statementBalance Float     @map("statement_balance")
  bookBalance      Float     @default(0) @map("book_balance")
  /// OPEN | COMPLETED
  status           String    @default("OPEN")
  createdBy        String    @map("created_by")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt     @map("updated_at")

  bankAccount  BankAccount      @relation(fields: [bankAccountId], references: [id])
  transactions BankTransaction[]

  @@map("reconciliations")
}

model BankTransaction {
  id                   String    @id @default(cuid())
  reconciliationId     String    @map("reconciliation_id")
  transactionDate      DateTime  @map("transaction_date")
  description          String
  amount               Float
  matchedJournalLineId String?   @map("matched_journal_line_id")
  isMatched            Boolean   @default(false) @map("is_matched")
  createdAt            DateTime  @default(now()) @map("created_at")

  reconciliation     Reconciliation    @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  matchedJournalLine JournalEntryLine? @relation(fields: [matchedJournalLineId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("bank_transactions")
}

// ========== NEPAL LOCALIZATION – Phase 5 ==========

model BsCalendar {
  id           String   @id @default(cuid())
  adDate       DateTime @unique @map("ad_date")
  bsYear       Int      @map("bs_year")
  bsMonth      Int      @map("bs_month")
  bsDay        Int      @map("bs_day")
  bsDateString String   @unique @map("bs_date_string")
  isHoliday    Boolean  @default(false) @map("is_holiday")
  holidayName  String?  @map("holiday_name")

  @@index([bsYear, bsMonth])
  @@map("bs_calendar")
}

model VatConfig {
  id             String    @id @default(cuid())
  organizationId String    @unique @map("organization_id")
  registrationNo String?   @map("registration_no")
  defaultRate    Float     @default(0.13) @map("default_rate")
  isRegistered   Boolean   @default(false) @map("is_registered")
  effectiveFrom  DateTime? @map("effective_from")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  vatReturns   VatReturn[]

  @@map("vat_configs")
}

model VatReturn {
  id              String    @id @default(cuid())
  vatConfigId     String    @map("vat_config_id")
  periodStart     DateTime  @map("period_start")
  periodEnd       DateTime  @map("period_end")
  salesAmount     Float     @default(0) @map("sales_amount")
  purchaseAmount  Float     @default(0) @map("purchase_amount")
  vatCollected    Float     @default(0) @map("vat_collected")
  vatPaid         Float     @default(0) @map("vat_paid")
  netVat          Float     @default(0) @map("net_vat")
  /// DRAFT | FILED
  status          String    @default("DRAFT")
  filedAt         DateTime? @map("filed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  vatConfig VatConfig @relation(fields: [vatConfigId], references: [id])

  @@map("vat_returns")
}

model TdsConfig {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  /// e.g. "52", "87", "88"
  section        String
  description    String?
  rateThreshold  Float?    @map("rate_threshold")
  /// Decimal fraction e.g. 0.015 for 1.5%
  rate           Float
  effectiveFrom  DateTime  @map("effective_from")
  effectiveTo    DateTime? @map("effective_to")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt      @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  deductions   TdsDeduction[]

  @@map("tds_configs")
}

model TdsDeduction {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  vendorId       String   @map("vendor_id")
  tdsConfigId    String   @map("tds_config_id")
  section        String
  paymentAmount  Float    @map("payment_amount")
  tdsAmount      Float    @map("tds_amount")
  certificateNo  String?  @map("certificate_no")
  paymentDate    DateTime @map("payment_date")
  /// e.g. "2080/81"
  fiscalYear     String   @map("fiscal_year")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  vendor    Vendor    @relation(fields: [vendorId], references: [id])
  tdsConfig TdsConfig @relation(fields: [tdsConfigId], references: [id])

  @@map("tds_deductions")
}
