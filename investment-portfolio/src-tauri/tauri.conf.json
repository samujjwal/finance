{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "JCL Investment Portfolio",
  "version": "1.0.0",
  "identifier": "com.jcl.investment-portfolio",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "JCL Investment Portfolio",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' http://localhost:41337 ws://localhost:41337; font-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "category": "Finance",
    "copyright": "JCL Investment",
    "publisher": "JCL Investment",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "Professional Investment Portfolio Management Application with desktop integration",
    "shortDescription": "Manage and analyze your investment portfolio",
    "targets": "all",
    "resources": {
      "resources/node/bin": "node/bin",
      "resources/server": "server",
      "../dist": "dist"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
